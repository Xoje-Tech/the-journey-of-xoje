---
interface Props {
  id?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  icon?: { src: string; alt: string };
}

const { id, type = 'button', class: className = '', icon } = Astro.props;
---

<button id={id} type={type} class={`retro-btn ${className}`}>
  {icon ? (
    <>
      <img class="retro-btn-icon" src={icon.src} alt={icon.alt} />
      <span data-retro-label><slot /></span>
    </>
  ) : (
    <slot />
  )}
</button>

<style>
  .retro-btn {
    border-radius: 0;
    border: 2px solid #09090b;
    background-color: #1c1c1f;
    color: #f4f4f5;
    padding: 8px 16px;
    font-family: ui-monospace, 'JetBrains Mono', Menlo, Consolas, monospace;
    font-size: 14px;
    font-weight: bold;
    cursor: pointer;
    box-shadow: 4px 4px 0px #09090b;
    /*
     * Transition only the background-color. Animating `all` causes a
     * visible blink when focus moves between buttons via JS
     * (the browser paints the "no-focus" frame before the focused
     * frame, and the transition interpolates across the discontinuity).
     * Animating background-color only keeps hover/focus transitions
     * smooth without affecting layout-affecting properties like
     * box-shadow or transform.
     */
    transition: background-color 100ms ease;
    user-select: none;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-align: center;
  }

  .retro-btn-icon {
    width: 24px;
    height: 24px;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    display: block;
    flex-shrink: 0;
  }

  .retro-btn:hover {
    background-color: #27272a;
  }

  .retro-btn:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0px #09090b;
    background-color: #3f3f46;
  }

  /*
   * Focus ring — Slice D (WU-1) needs a visible focus indicator so
   * keyboard and gamepad navigation is usable. Focus MUST look exactly
   * like hover: same background, same drop-shadow, same depth. No
   * extras, no outlines — the only visual cue is the lighter
   * background that hover already provides.
   *
   * The selector-list groups :hover and :focus-visible so the two
   * states stay coupled by construction. If hover changes later, focus
   * changes with it.
   */
  .retro-btn:hover,
  .retro-btn:focus-visible {
    background-color: #27272a;
  }
</style>
