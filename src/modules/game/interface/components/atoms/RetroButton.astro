---
interface Props {
  id?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  icon?: { src: string; alt: string };
}

const { id, type = 'button', class: className = '', icon } = Astro.props;
---

<button id={id} type={type} class={`retro-btn ${className}`}>
  {icon ? (
    <>
      <img class="retro-btn-icon" src={icon.src} alt={icon.alt} />
      <span data-retro-label><slot /></span>
    </>
  ) : (
    <slot />
  )}
</button>

<style>
  .retro-btn {
    border-radius: 0;
    border: 2px solid #09090b;
    background-color: #1c1c1f;
    color: #f4f4f5;
    padding: 8px 16px;
    font-family: ui-monospace, 'JetBrains Mono', Menlo, Consolas, monospace;
    font-size: 14px;
    font-weight: bold;
    cursor: pointer;
    box-shadow: 4px 4px 0px #09090b;
    transition: all 100ms ease;
    user-select: none;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-align: center;
  }

  .retro-btn-icon {
    width: 24px;
    height: 24px;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    display: block;
    flex-shrink: 0;
  }

  .retro-btn:hover {
    background-color: #27272a;
  }

  .retro-btn:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0px #09090b;
    background-color: #3f3f46;
  }

  /*
   * Focus ring — Slice D (WU-1) needs a visible focus indicator so
   * keyboard and gamepad navigation is usable.
   *
   * Design rule: a focused button MUST look the same as a hovered
   * button (selected-and-ready-to-fire semantics). We copy :hover
   * styles verbatim and add a single extra indicator on top — the
   * white border color — so keyboard users see a clear "I'm here"
   * cue without losing the retro chunky-shadow aesthetic.
   *
   * Adding `, :focus-visible` to the hover rule would work too but
   * creates a selector-list coupling that future tweaks might miss;
   * duplicating the three properties here keeps the contract local
   * and explicit.
   */
  .retro-btn:hover,
  .retro-btn:focus-visible {
    background-color: #27272a;
    border-color: #f4f4f5;
  }

  /*
   * Extra focus-only cue beyond the hover look: a 2px solid black ring
   * just outside the border. This survives on any background and is
   * distinguishable from the drop-shadow. We don't reuse the
   * drop-shadow slot here — that one carries the "selected" 3D depth
   * and changing it for focus would diverge from hover too much.
   */
  .retro-btn:focus-visible {
    outline: 2px solid #09090b;
    outline-offset: 2px;
  }
</style>
