---
interface Props {
  id: string;
  title: string;
  closeId: string;
  class?: string;
  triggerId?: string;
}

const { id, title, closeId, class: className = '', triggerId } = Astro.props;
---

<dialog id={id} class={`no-print retro-modal ${className}`} data-trigger-id={triggerId}>
  <div class="modal-content">
    <header class="modal-header">
      <h2>{title}</h2>
      <button id={closeId} type="button" aria-label="Close modal" class="close-btn">&times;</button>
    </header>
    <div class="modal-body">
      <slot />
    </div>
  </div>
</dialog>

<style>
  .retro-modal {
    border: none;
    border-radius: 0;
    border: 2px solid #09090b;
    background-color: #1c1c1f;
    color: #f4f4f5;
    max-width: 550px;
    width: 90%;
    box-shadow: 8px 8px 0px rgba(9, 9, 11, 0.5);
    z-index: 30;
    padding: 0;
  }

  .retro-modal::backdrop {
    background: rgba(9, 9, 11, 0.7);
    backdrop-filter: blur(2px);
  }

  .modal-content {
    display: flex;
    flex-direction: column;
    max-height: 80vh;
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .modal-header h2 {
    margin: 0;
    font-size: 14px;
    font-family: ui-monospace, 'JetBrains Mono', monospace;
    font-weight: bold;
    color: #f4f4f5;
  }

  .close-btn {
    background: none;
    border: none;
    color: #a1a1aa;
    font-size: 24px;
    cursor: pointer;
    line-height: 1;
    padding: 0;
  }

  .close-btn:hover {
    color: #f4f4f5;
  }

  .modal-body {
    padding: 20px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const modals = document.querySelectorAll('.retro-modal');
    modals.forEach((m) => {
      const modal = m as HTMLDialogElement;

      const handleClose = () => {
        const triggerId = modal.getAttribute('data-trigger-id');
        if (triggerId) {
          const trigger = document.getElementById(triggerId);
          if (trigger) {
            trigger.setAttribute('aria-expanded', 'false');
            trigger.focus();
          }
        }
      };

      // Focus trap: keep Tab cycling within modal's focusable elements.
      const getFocusable = () =>
        Array.from(
          modal.querySelectorAll<HTMLElement>(
            'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])',
          ),
        );

      modal.addEventListener('keydown', (e) => {
        if (e.key !== 'Tab') return;
        const focusables = getFocusable();
        if (focusables.length === 0) return;
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        const active = document.activeElement as HTMLElement | null;
        if (e.shiftKey && active === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && active === last) {
          e.preventDefault();
          first.focus();
        }
      });

      // Gamepad A → simulate Enter on the currently-focused element.
      // Mirrors what keyboard users get for free: if focus is on a button,
      // pressing A activates it (e.g. closing the modal via close-btn).
      // We do NOT force-close the modal here so the focus-trap semantics
      // are preserved: A respects whatever the user has navigated to with
      // the D-pad / Tab focus trap.
      modal.addEventListener('gamepad-a', () => {
        if (!modal.open) return;
        const active = document.activeElement as HTMLElement | null;
        if (active && modal.contains(active)) {
          active.click();
        } else {
          // No focus inside: behave like a primary action — close.
          modal.close();
          handleClose();
        }
      });

      // Gamepad B → close the modal (cancel semantics). Symmetric to the
      // click-outside handler below.
      modal.addEventListener('gamepad-b', () => {
        if (!modal.open) return;
        modal.close();
        handleClose();
      });

      // Gamepad D-pad navigation (Slice C WU-4). Cycles focus through
      // the modal's focusables. Up/Down move to prev/next (matches the
      // expected mental model for vertical lists — Settings and Controls
      // modals have stacked controls). Left/Right also cycle but the
      // effect is the same — kept as a stub for future horizontal
      // layouts (e.g. icon grids) without changing the public contract.
      //
      // Edge-detect is handled upstream in init.ts, so each direction
      // event fires exactly once per physical press — no repeat spam.
      const moveFocus = (delta: number) => {
        if (!modal.open) return;
        const focusables = getFocusable();
        if (focusables.length === 0) return;
        const active = document.activeElement as HTMLElement | null;
        let idx = active ? focusables.indexOf(active) : -1;
        if (idx === -1) {
          // Focus not in modal: take the first focusable.
          idx = 0;
        } else {
          // Wrap-around cycle.
          idx = (idx + delta + focusables.length) % focusables.length;
        }
        focusables[idx]?.focus();
      };

      modal.addEventListener('gamepad-dpad-up', () => moveFocus(-1));
      modal.addEventListener('gamepad-dpad-down', () => moveFocus(1));
      modal.addEventListener('gamepad-dpad-left', () => moveFocus(-1));
      modal.addEventListener('gamepad-dpad-right', () => moveFocus(1));

      // Move focus into the modal when it opens.
      const observer = new MutationObserver(() => {
        if (modal.open) {
          const focusables = getFocusable();
          if (focusables.length > 0) focusables[0].focus();
        }
      });
      observer.observe(modal, { attributes: true, attributeFilter: ['open'] });

      modal.addEventListener('click', (e) => {
        const rect = modal.getBoundingClientRect();
        if (
          e.clientX < rect.left ||
          e.clientX > rect.right ||
          e.clientY < rect.top ||
          e.clientY > rect.bottom
        ) {
          modal.close();
          handleClose();
        }
      });

      const closeBtn = modal.querySelector('.close-btn');
      if (closeBtn) {
        closeBtn.addEventListener('click', () => {
          modal.close();
          handleClose();
        });
      }
    });
  });
</script>
