---
// GameViewport encapsulates the canvas and engine lifecycle.
---

<canvas id="game-canvas" aria-hidden="true" role="img"></canvas>

<script>
  import { init } from "@/modules/game/infrastructure/init";
  import playerSpritesheet from '@/assets/player.png';
  import { isStartedStore, collectedSkillsStore } from "@/modules/game/application/store";
  import type { GameStateUpdateEventPayload } from "@/modules/game/domain/types";

  // Dynamically resolve all skill shield sprites using Vite's glob import
  const skillSprites = import.meta.glob<{ default: { src: string } }>('@/assets/skills/*.png', { eager: true });
  const skillSpritePaths: Record<string, string> = {};
  for (const [key, value] of Object.entries(skillSprites)) {
    const filename = key.split('/').pop()?.replace('.png', '') || '';
    skillSpritePaths[filename] = value.default.src;
  }

  // Dynamically resolve biome decoration sprites using Vite's glob import
  const decorationSprites = import.meta.glob<{ default: { src: string } }>('@/assets/biomes/**/*.png', { eager: true });
  const decorationSpritePaths: Record<string, string> = {};
  for (const [key, value] of Object.entries(decorationSprites)) {
    const marker = '/assets/';
    const assetPath = key.includes(marker) ? key.slice(key.indexOf(marker) + marker.length) : key;
    decorationSpritePaths[assetPath] = value.default.src;
  }

  document.addEventListener('DOMContentLoaded', () => {
    const c = document.getElementById('game-canvas');
    if (c instanceof HTMLCanvasElement) {
      const locale = (document.body.getAttribute('data-locale') as 'es' | 'en') || 'es';
      const handle = init(c, {
        spritesheetPath: playerSpritesheet.src,
        skillSpritePaths,
        decorationSpritePaths,
        locale
      });
      window.gameHandle = handle;

      // Subscribe to isStartedStore to run handle.start() when started
      isStartedStore.subscribe((started) => {
        if (started && typeof handle.start === 'function') {
          handle.start();
        }
      });

      // Bridge game-state-update events into the Nanostore
      window.addEventListener('game-state-update', (e: Event) => {
        const customEvent = e as CustomEvent<GameStateUpdateEventPayload>;
        const { unlockedId } = customEvent.detail;
        const current = collectedSkillsStore.get();
        if (!current.includes(unlockedId)) {
          collectedSkillsStore.set([...current, unlockedId]);
        }
      });
    }
  });
</script>
