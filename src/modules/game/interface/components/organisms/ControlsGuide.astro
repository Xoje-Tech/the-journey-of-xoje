---
import uiEs from "@/i18n/ui.es.json";
import uiEn from "@/i18n/ui.en.json";
import RetroModal from "@/modules/game/interface/components/atoms/RetroModal.astro";
import NesController from "@/modules/game/interface/components/molecules/NesController.astro";

interface Props {
  locale: 'es' | 'en';
}

const { locale } = Astro.props;
const ui = locale === 'es' ? uiEs : uiEn;
---

<RetroModal id="controls-modal" title={ui.game.controlsTitle} closeId="close-controls-btn">
  <NesController locale={locale} />
</RetroModal>
