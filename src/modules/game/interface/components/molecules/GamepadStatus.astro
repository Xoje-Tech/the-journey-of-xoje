---
import uiEs from "@/i18n/ui.es.json";
import uiEn from "@/i18n/ui.en.json";

interface Props {
  locale: 'es' | 'en';
}

const { locale } = Astro.props;
const ui = locale === 'es' ? uiEs : uiEn;
---

<div class="setting-item">
  <span class="setting-label">{ui.game.gamepadLabel}</span>
  <span
    id="gamepad-status-label"
    class="gamepad-status-indicator"
    data-text-connected={ui.game.connected}
    data-text-disconnected={ui.game.disconnected}
  >
    {ui.game.disconnected}
  </span>
</div>

<style>
  .setting-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 20px;
    font-family: ui-monospace, 'JetBrains Mono', monospace;
    font-size: 13px;
  }

  .setting-label {
    color: #a1a1aa;
  }

  .gamepad-status-indicator {
    font-weight: bold;
    font-size: 14px;
    text-shadow: 1px 1px 0px #09090b;
    transition: color 0.2s ease;
    color: #09090b; /* default inactive */
  }
</style>

<script>
  import { gamepadConnectedStore } from "@/modules/game/application/store";

  const label = document.getElementById('gamepad-status-label');
  if (label) {
    gamepadConnectedStore.subscribe((connected) => {
      const textConnected = label.getAttribute('data-text-connected') || 'Connected';
      const textDisconnected = label.getAttribute('data-text-disconnected') || 'Not Connected';

      label.textContent = connected ? textConnected : textDisconnected;
      label.style.color = connected ? '#eab308' : '#09090b';
    });
  }
</script>
