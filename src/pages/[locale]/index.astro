---
import { getCollection, render } from 'astro:content';
import CvLayout from '../../layouts/CvLayout.astro';
import CvDocument from '../../components/CvDocument.astro';
import uiEs from '../../i18n/ui.es.json';
import uiEn from '../../i18n/ui.en.json';

export async function getStaticPaths() {
  return [
    { params: { locale: 'es' } },
    { params: { locale: 'en' } },
  ];
}

// `Astro.params.locale` is typed loosely by Astro; we narrow here.
const rawLocale = Astro.params.locale;
if (rawLocale !== 'es' && rawLocale !== 'en') {
  throw new Error(`Unsupported locale: ${rawLocale}`);
}
const locale = rawLocale;
const ui = locale === 'es' ? uiEs : uiEn;

// Content-collection lookup. The collection loader is `glob({ pattern: 'cv.*.md' })`,
// so the entry id is exactly `cv.es.md` or `cv.en.md`.
const entries = await getCollection('cv');
const targetId = `cv.${locale}.md`;
const entry = entries.find((e) => e.id === targetId);

if (!entry) {
  throw new Error(
    `CV entry not found for locale "${locale}". ` +
      `Expected "${targetId}" under src/content/. ` +
      `Did you run "pnpm build:cv"?`,
  );
}

// Astro 6: `render(entry)` is the new top-level API for markdown entries.
// The legacy `entry.render()` is no longer attached on collection entries
// produced by the `glob` loader.
const { Content } = await render(entry);
---

<CvLayout locale={locale}>
  <CvDocument locale={locale} ui={ui}>
    <Content slot="body" />
  </CvDocument>
</CvLayout>
