---
import { getCollection, render } from 'astro:content';
import CvLayout from '../../layouts/CvLayout.astro';
import CvDocument from '../../components/cv/CvDocument.astro';
import GameViewport from '../../components/game/GameViewport.astro';
import StartScreen from '../../components/game/StartScreen.astro';
import SettingsPanel from '../../components/game/SettingsPanel.astro';
import ControlsGuide from '../../components/game/ControlsGuide.astro';
import PauseButton from '../../components/game/PauseButton.astro';
import TechBag from '../../components/game/TechBag.astro';
import QualBag from '../../components/game/QualBag.astro';
import SoftBag from '../../components/game/SoftBag.astro';
import DialogOverlay from '../../components/game/DialogOverlay.astro';
import uiEs from '../../i18n/ui.es.json';
import uiEn from '../../i18n/ui.en.json';

export async function getStaticPaths() {
  return [
    { params: { locale: 'es' } },
    { params: { locale: 'en' } },
  ];
}

const rawLocale = Astro.params.locale;
if (rawLocale !== 'es' && rawLocale !== 'en') {
  throw new Error(`Unsupported locale: ${rawLocale}`);
}
const locale = rawLocale;
const ui = locale === 'es' ? uiEs : uiEn;

const entries = await getCollection('cv');
const targetId = `cv.${locale}.md`;
const entry = entries.find((e) => e.id === targetId);

if (!entry) {
  throw new Error(
    `CV entry not found for locale "${locale}". ` +
      `Expected "${targetId}" under src/content/. ` +
      `Did you run "pnpm build:cv"?`,
  );
}

const { Content } = await render(entry);
---

<CvLayout locale={locale}>
  <!-- Game engine viewport and retro screen-only overlays -->
  <GameViewport />
  <DialogOverlay locale={locale} />
  <StartScreen locale={locale} />
  <SettingsPanel locale={locale} />
  <ControlsGuide locale={locale} />

  <!-- Top-right HUD buttons container -->
  <div class="hud-top-right no-print">
    <PauseButton locale={locale} />
    <SoftBag locale={locale} />
    <QualBag locale={locale} />
    <TechBag locale={locale} />
  </div>

  <!-- Clean, print-ready CV layout (fully decoupled from game layers) -->
  <CvDocument locale={locale} ui={ui}>
    <Content slot="body" />
  </CvDocument>
</CvLayout>

<style>
  .hud-top-right {
    position: fixed;
    top: 16px;
    right: 16px;
    z-index: 20;
    display: flex;
    gap: 8px;
    align-items: center;
  }

  @media (max-width: 480px) {
    .hud-top-right :global(.hud-label),
    .hud-top-right :global(.pause-label) {
      display: none !important;
    }
  }
</style>
