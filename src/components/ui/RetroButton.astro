---
interface Props {
  id?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
}

const { id, type = 'button', class: className = '' } = Astro.props;
---

<button id={id} type={type} class={`retro-btn ${className}`}>
  <slot />
</button>

<style>
  .retro-btn {
    border-radius: 0;
    border: 2px solid #09090b;
    background-color: #1c1c1f;
    color: #f4f4f5;
    padding: 8px 16px;
    font-family: ui-monospace, "JetBrains Mono", Menlo, Consolas, monospace;
    font-size: 14px;
    font-weight: bold;
    cursor: pointer;
    box-shadow: 4px 4px 0px #09090b;
    transition: all 100ms ease;
    user-select: none;
    display: inline-block;
    text-align: center;
  }

  .retro-btn:hover {
    background-color: #27272a;
  }

  .retro-btn:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0px #09090b;
    background-color: #3f3f46;
  }
</style>
