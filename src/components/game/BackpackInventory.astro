---
import { SKILL_TEMPLATES } from '../../game/init';
import RetroModal from '../ui/RetroModal.astro';
import SkillCard from '../ui/SkillCard.astro';

const CATEGORY_TECHNICAL = 'technical';
const CATEGORY_QUALITATIVE = 'qualitative';
---

<RetroModal id="skill-matrix-modal" title="Backpack — Collected Skills" closeId="close-modal-btn">
  <section class="skills-grid-section">
    <h3>Technical Skills</h3>
    <div class="skills-grid" id="tech-skills-grid">
      {SKILL_TEMPLATES.filter(s => s.category === CATEGORY_TECHNICAL).map(s => (
        <SkillCard id={s.id} name={s.name} biome={s.biome} />
      ))}
    </div>
  </section>

  <section class="skills-grid-section">
    <h3>Qualitative Skills</h3>
    <div class="skills-grid" id="qual-skills-grid">
      {SKILL_TEMPLATES.filter(s => s.category === CATEGORY_QUALITATIVE).map(s => (
        <SkillCard id={s.id} name={s.name} biome={s.biome} />
      ))}
    </div>
  </section>
</RetroModal>

<style>
  .skills-grid-section h3 {
    margin: 0 0 12px 0;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.4);
    font-family: ui-monospace, "JetBrains Mono", monospace;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 10px;
  }
</style>

<script>
  import { collectedSkillsStore } from '../../game/store';

  document.addEventListener('DOMContentLoaded', () => {
    collectedSkillsStore.subscribe((skills) => {
      skills.forEach((id) => {
        const card = document.getElementById(`skill-card-${id}`);
        if (card) {
          card.classList.remove('skill-locked');
          card.classList.add('skill-unlocked');
        }
      });
    });
  });
</script>
