---
import { SKILL_TEMPLATES } from '../../game/init';
import RetroModal from '../ui/RetroModal.astro';
---

<RetroModal id="skill-matrix-modal" title="Backpack — Collected Skills" closeId="close-modal-btn">
  <section class="skills-grid-section">
    <h3>Technical Skills</h3>
    <div class="skills-grid" id="tech-skills-grid">
      {SKILL_TEMPLATES.filter(s => s.category === 'technical').map(s => (
        <div class="skill-card skill-locked" id={`skill-card-${s.id}`} data-skill-id={s.id}>
          <span class="skill-lock-icon">🔒</span>
          <span class="skill-unlock-badge">✅</span>
          <div class="skill-details">
            <span class="skill-name">{s.name}</span>
            <span class="skill-biome">{s.biome}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="skills-grid-section">
    <h3>Qualitative Skills</h3>
    <div class="skills-grid" id="qual-skills-grid">
      {SKILL_TEMPLATES.filter(s => s.category === 'qualitative').map(s => (
        <div class="skill-card skill-locked" id={`skill-card-${s.id}`} data-skill-id={s.id}>
          <span class="skill-lock-icon">🔒</span>
          <span class="skill-unlock-badge">✅</span>
          <div class="skill-details">
            <span class="skill-name">{s.name}</span>
            <span class="skill-biome">{s.biome}</span>
          </div>
        </div>
      ))}
    </div>
  </section>
</RetroModal>

<style>
  .skills-grid-section h3 {
    margin: 0 0 12px 0;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.4);
    font-family: ui-monospace, "JetBrains Mono", monospace;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 10px;
  }

  .skill-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    transition: all 0.2s ease;
  }

  .skill-name {
    display: block;
    font-size: 13px;
    font-weight: 500;
  }

  .skill-biome {
    display: block;
    font-size: 10px;
    color: rgba(255, 255, 255, 0.4);
    margin-top: 2px;
  }

  /* Locked Skill Card */
  .skill-card.skill-locked {
    background: rgba(255, 255, 255, 0.01);
    border-color: rgba(255, 255, 255, 0.03);
  }

  .skill-card.skill-locked .skill-name {
    color: rgba(255, 255, 255, 0.25);
  }

  .skill-card.skill-locked .skill-unlock-badge {
    display: none;
  }

  .skill-card.skill-locked .skill-lock-icon {
    font-size: 13px;
    opacity: 0.3;
  }

  /* Unlocked Skill Card */
  .skill-card.skill-unlocked {
    background: rgba(11, 102, 194, 0.08);
    border-color: rgba(11, 102, 194, 0.35);
  }

  .skill-card.skill-unlocked .skill-name {
    color: #ffffff;
  }

  .skill-card.skill-unlocked .skill-lock-icon {
    display: none;
  }

  .skill-card.skill-unlocked .skill-unlock-badge {
    font-size: 12px;
  }
</style>

<script>
  import { collectedSkillsStore } from '../../game/store';

  document.addEventListener('DOMContentLoaded', () => {
    collectedSkillsStore.subscribe((skills) => {
      skills.forEach((id) => {
        const card = document.getElementById(`skill-card-${id}`);
        if (card) {
          card.classList.remove('skill-locked');
          card.classList.add('skill-unlocked');
        }
      });
    });
  });
</script>
