{
  "name": "the-journey-of-xoje",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Static portfolio whose print output IS a Harvard-style CV. CV content is materialized at build time from a static DATA snapshot under tests/fixtures/portfolio/.",
  "scripts": {
    "build:cv": "node scripts/build-cv-static.mjs",
    "predev": "node scripts/build-cv-static.mjs",
    "dev": "astro dev",
    "generate-skill-sprites": "SDL_VIDEODRIVER=dummy SDL_AUDIODRIVER=dummy LD_LIBRARY_PATH=/home/hermes/tools/squashfs-root/usr/lib /home/hermes/tools/squashfs-root/usr/bin/libresprite --batch --script scripts/generate-skill-sprites.js",
    "generate-start-icons": "SDL_VIDEODRIVER=dummy SDL_AUDIODRIVER=dummy LD_LIBRARY_PATH=/home/hermes/tools/squashfs-root/usr/lib /home/hermes/tools/squashfs-root/usr/bin/libresprite --batch --script scripts/generate-start-icons.js",
    "build:astro": "astro build",
    "prebuild": "node scripts/build-cv-static.mjs",
    "build": "pnpm build:cv && astro build",
    "preview": "astro preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,astro,json,md,mjs,yml,yaml}\""
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.9.0",
  "dependencies": {
    "astro": "^6.0.0",
    "nanostores": "1.4.0"
  },
  "devDependencies": {
    "@axe-core/cli": "4.12.1",
    "@eslint/js": "10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "10.7.0",
    "eslint-plugin-astro": "3.0.1",
    "eslint-plugin-sonarjs": "4.2.0",
    "lighthouse": "13.4.0",
    "pa11y": "9.1.1",
    "prettier": "^3.0.0",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "8.64.0",
    "vitest": "^1.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "chromedriver",
      "puppeteer"
    ]
  }
}